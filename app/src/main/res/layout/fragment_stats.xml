<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Menü Butonu -->
        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_menu_24"
            android:contentDescription="@string/menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/slate_dark" />

        <TextView
            android:id="@+id/tvStatsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="@string/my_statistics"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/llStatsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvStatsTitle">

            <!-- 1. KART: GENEL İLERLEME -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTitle1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Genel İlerleme"
                        android:textColor="@color/slate_light"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/circularProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:indicatorColor="@color/accent_indigo"
                        app:indicatorSize="140dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle1"
                        app:trackColor="@color/divider"
                        app:trackThickness="12dp" />

                    <TextView
                        android:id="@+id/tvTotalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 150"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/circularProgress"
                        app:layout_constraintEnd_toEndOf="@id/circularProgress"
                        app:layout_constraintStart_toStartOf="@id/circularProgress"
                        app:layout_constraintTop_toTopOf="@id/circularProgress" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. KART: SEVİYE İLERLEMESİ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Seviye Bazlı Başarı"
                        android:textColor="@color/slate_light"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- A1 Satırı -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:id="@+id/lblA1" android:layout_width="35dp" android:layout_height="wrap_content" android:text="A1" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressA1" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/lblA1" android:layout_toStartOf="@+id/valA1" android:layout_marginHorizontal="8dp"
                            app:indicatorColor="@color/accent_indigo" app:trackColor="@color/divider" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                        <TextView android:id="@+id/valA1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25" android:textColor="@color/text_primary"/>
                    </RelativeLayout>

                    <!-- A2 Satırı -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:id="@+id/lblA2" android:layout_width="35dp" android:layout_height="wrap_content" android:text="A2" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressA2" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/lblA2" android:layout_toStartOf="@+id/valA2" android:layout_marginHorizontal="8dp"
                            app:indicatorColor="@color/accent_indigo" app:trackColor="@color/divider" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                        <TextView android:id="@+id/valA2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25" android:textColor="@color/text_primary"/>
                    </RelativeLayout>

                    <!-- B1 Satırı -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:id="@+id/lblB1" android:layout_width="35dp" android:layout_height="wrap_content" android:text="B1" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressB1" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/lblB1" android:layout_toStartOf="@+id/valB1" android:layout_marginHorizontal="8dp"
                            app:indicatorColor="@color/accent_indigo" app:trackColor="@color/divider" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                        <TextView android:id="@+id/valB1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25" android:textColor="@color/text_primary"/>
                    </RelativeLayout>

                    <!-- B2 Satırı -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:id="@+id/lblB2" android:layout_width="35dp" android:layout_height="wrap_content" android:text="B2" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressB2" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/lblB2" android:layout_toStartOf="@+id/valB2" android:layout_marginHorizontal="8dp"
                            app:indicatorColor="@color/accent_indigo" app:trackColor="@color/divider" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                        <TextView android:id="@+id/valB2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25" android:textColor="@color/text_primary"/>
                    </RelativeLayout>

                    <!-- C1 Satırı -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:id="@+id/lblC1" android:layout_width="35dp" android:layout_height="wrap_content" android:text="C1" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressC1" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/lblC1" android:layout_toStartOf="@+id/valC1" android:layout_marginHorizontal="8dp"
                            app:indicatorColor="@color/accent_indigo" app:trackColor="@color/divider" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                        <TextView android:id="@+id/valC1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25" android:textColor="@color/text_primary"/>
                    </RelativeLayout>

                    <!-- C2 Satırı -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:id="@+id/lblC2" android:layout_width="35dp" android:layout_height="wrap_content" android:text="C2" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressC2" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/lblC2" android:layout_toStartOf="@+id/valC2" android:layout_marginHorizontal="8dp"
                            app:indicatorColor="@color/accent_indigo" app:trackColor="@color/divider" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                        <TextView android:id="@+id/valC2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25" android:textColor="@color/text_primary"/>
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. KART: KELİME ANATOMİSİ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Kelime Anatomisi"
                        android:textColor="@color/slate_light"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="İsim (Noun)" android:textColor="@color/text_primary"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressNoun"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                        app:indicatorColor="@color/type_noun" app:trackThickness="8dp" app:trackCornerRadius="4dp" app:trackColor="@color/divider"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fiil (Verb)" android:textColor="@color/text_primary"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressVerb"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                        app:indicatorColor="@color/type_verb" app:trackThickness="8dp" app:trackCornerRadius="4dp" app:trackColor="@color/divider"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sıfat (Adjective)" android:textColor="@color/text_primary"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressAdjective"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        app:indicatorColor="@color/type_adj" app:trackThickness="8dp" app:trackCornerRadius="4dp" app:trackColor="@color/divider"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
