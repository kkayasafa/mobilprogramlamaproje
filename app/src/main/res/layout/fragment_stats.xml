<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="İstatistiklerim"
            android:textColor="#2D3436"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- 1. KART: GENEL İLERLEME -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvTitle1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genel İlerleme"
                    android:textColor="#636E72"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/circularProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:indicatorColor="#6C5CE7"
                    app:indicatorSize="140dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle1"
                    app:trackColor="#F0F0F0"
                    app:trackThickness="12dp" />

                <TextView
                    android:id="@+id/tvTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 150"
                    android:textColor="#2D3436"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/circularProgress"
                    app:layout_constraintEnd_toEndOf="@id/circularProgress"
                    app:layout_constraintStart_toStartOf="@id/circularProgress"
                    app:layout_constraintTop_toTopOf="@id/circularProgress" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. KART: SEVİYE İLERLEMESİ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Seviye Bazlı Başarı"
                    android:textColor="#636E72"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- A1 Satırı -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/lblA1" android:layout_width="35dp" android:layout_height="wrap_content" android:text="A1" android:textStyle="bold"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressA1" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/lblA1" android:layout_toStartOf="@+id/valA1" android:layout_marginHorizontal="8dp"
                        app:indicatorColor="#6C5CE7" app:trackColor="#F0F0F0" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                    <TextView android:id="@+id/valA1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25"/>
                </RelativeLayout>

                <!-- A2 Satırı -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/lblA2" android:layout_width="35dp" android:layout_height="wrap_content" android:text="A2" android:textStyle="bold"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressA2" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/lblA2" android:layout_toStartOf="@+id/valA2" android:layout_marginHorizontal="8dp"
                        app:indicatorColor="#A29BFE" app:trackColor="#F0F0F0" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                    <TextView android:id="@+id/valA2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25"/>
                </RelativeLayout>

                <!-- B1 Satırı -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/lblB1" android:layout_width="35dp" android:layout_height="wrap_content" android:text="B1" android:textStyle="bold"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressB1" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/lblB1" android:layout_toStartOf="@+id/valB1" android:layout_marginHorizontal="8dp"
                        app:indicatorColor="#00B894" app:trackColor="#F0F0F0" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                    <TextView android:id="@+id/valB1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25"/>
                </RelativeLayout>

                <!-- B2 Satırı -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/lblB2" android:layout_width="35dp" android:layout_height="wrap_content" android:text="B2" android:textStyle="bold"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressB2" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/lblB2" android:layout_toStartOf="@+id/valB2" android:layout_marginHorizontal="8dp"
                        app:indicatorColor="#55EFC4" app:trackColor="#F0F0F0" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                    <TextView android:id="@+id/valB2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25"/>
                </RelativeLayout>

                <!-- C1 Satırı -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/lblC1" android:layout_width="35dp" android:layout_height="wrap_content" android:text="C1" android:textStyle="bold"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressC1" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/lblC1" android:layout_toStartOf="@+id/valC1" android:layout_marginHorizontal="8dp"
                        app:indicatorColor="#FAB1A0" app:trackColor="#F0F0F0" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                    <TextView android:id="@+id/valC1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25"/>
                </RelativeLayout>

                <!-- C2 Satırı -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:id="@+id/lblC2" android:layout_width="35dp" android:layout_height="wrap_content" android:text="C2" android:textStyle="bold"/>
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressC2" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/lblC2" android:layout_toStartOf="@+id/valC2" android:layout_marginHorizontal="8dp"
                        app:indicatorColor="#E17055" app:trackColor="#F0F0F0" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>
                    <TextView android:id="@+id/valC2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0/25"/>
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. KART: KELİME ANATOMİSİ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Kelime Anatomisi"
                    android:textColor="#636E72"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="İsim (Noun)"/>
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressNoun"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                    android:progress="0" app:indicatorColor="#0984E3" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fiil (Verb)"/>
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressVerb"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                    android:progress="0" app:indicatorColor="#D63031" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sıfat (Adjective)"/>
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressAdjective"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:progress="0" app:indicatorColor="#F1C40F" app:trackThickness="8dp" app:trackCornerRadius="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. KART: ÇALIŞMA SERİSİ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_fire" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Günlük Seri: 3 Gün"
                        android:textColor="#2D3436"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Böyle devam et! Harika gidiyorsun."
                        android:textColor="#636E72"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>