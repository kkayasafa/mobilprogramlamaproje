<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Proje2" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 60% - Main Background -->
        <item name="android:windowBackground">@color/bg_main</item>

        <!-- 30% - Secondary -->
        <item name="colorPrimary">@color/slate_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- 10% - Accent -->
        <item name="colorAccent">@color/accent_indigo</item>
        <item name="colorSecondary">@color/accent_indigo</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface and Text -->
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Theme.Proje2" parent="Base.Theme.Proje2" />

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>
