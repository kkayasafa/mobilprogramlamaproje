<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Proje2" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 60% - Main Background -->
        <item name="android:windowBackground">@color/bg_main</item>

        <!-- 30% - Secondary -->
        <item name="colorPrimary">@color/slate_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- 10% - Accent -->
        <item name="colorAccent">@color/accent_indigo</item>
        <item name="colorSecondary">@color/accent_indigo</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface and Text -->
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Theme.Proje2" parent="Base.Theme.Proje2" />

    <style name="CircleAppearance">
        <item name="cornerSize">50%</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Bottom Nav Göstergesini Gizlemek İçin Tema Katmanı -->
    <style name="BottomNavOverlay">
        <item name="colorContainer">@android:color/transparent</item>
        <item name="itemActiveIndicatorStyle">@style/App.Custom.Indicator</item>
    </style>

    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/accent_light</item>
        <item name="android:width">48dp</item>
        <item name="android:height">48dp</item>
        <item name="marginHorizontal">0dp</item>
    </style>
</resources>
